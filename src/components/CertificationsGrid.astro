---
interface Cert {
  name: string;
  description?: string;
  /** Path under /public, e.g. /images/certifications/iso-14001.svg */
  logo?: string;
  /** Optional download link (PDF, etc.) */
  href?: string;
}
interface Props { items: Cert[]; }
const { items } = Astro.props;
---
<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 my-8">
  {items.map((c) => (
    <li class="group flex flex-col items-center text-center p-6 border border-ink/10 rounded-md bg-surface transition-all duration-200 ease-out hover:border-brand-500/40 hover:shadow-[0_8px_24px_-8px_rgba(0,0,0,0.10)]">
      {c.logo ? (
        <img
          src={c.logo}
          alt={`${c.name} certification badge`}
          width="160"
          height="160"
          loading="lazy"
          class="w-32 h-32 md:w-40 md:h-40 object-contain"
        />
      ) : (
        <div aria-hidden="true" class="w-32 h-32 md:w-40 md:h-40 bg-brand-500/5 rounded-md flex items-center justify-center">
          <span class="text-xs font-mono text-ink/65">{c.name.slice(0, 10)}</span>
        </div>
      )}
      <h3 class="mt-5 text-sm font-heavy text-ink leading-tight">{c.name}</h3>
      {c.description && <p class="mt-1 text-xs text-ink/65 leading-snug">{c.description}</p>}
      {c.href && (
        <a
          href={c.href}
          target="_blank"
          rel="noopener"
          class="mt-3 text-[11px] uppercase tracking-widest font-medium text-brand-500 hover:text-brand-accent transition-colors duration-fast"
        >Download PDF →</a>
      )}
    </li>
  ))}
</ul>

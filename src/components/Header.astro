---
import logo from '../assets/icons/logo.svg';
import Container from './Container.astro';
import MenuDrawer from './MenuDrawer.astro';
---
<header
  data-header
  class="fixed inset-x-0 top-0 z-40 transition-[background-color,backdrop-filter,box-shadow] duration-base ease-out-quint"
>
  <Container size="xl" class="flex items-center justify-between py-4 md:py-5">
    <a href="/" class="flex items-center" aria-label="Sonan Bunkers — home">
      <img src={logo.src} width={logo.width} height={logo.height} alt="Sonan Bunkers" class="h-8 w-auto md:h-10" loading="eager" />
    </a>
    <button
      data-menu-trigger
      class="inline-flex items-center gap-3 px-3 py-2 text-sm uppercase tracking-wide font-medium text-ink hover:text-brand-500 transition-colors duration-fast"
      type="button"
      aria-expanded="false"
      aria-controls="primary-menu"
    >
      <span class="hidden lg:inline">Menu</span>
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 9h18M5 14h18M5 19h18" />
      </svg>
    </button>
  </Container>
</header>
<MenuDrawer />
<script>import '../scripts/header.client';</script>

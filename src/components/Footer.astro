---
import Container from './Container.astro';
import { footerNav, footerLegal, social, companyContact } from '../data/navigation';
import logo from '../assets/icons/elysee-logo.svg';
const year = new Date().getFullYear();
---
<footer class="bg-surface text-ink">

  {/* ===== White section ===== */}
  <Container size="xl" class="pt-12 md:pt-16 pb-6">

    {/* ===== Top row: Brand block + Newsletter ===== */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 pb-10 md:pb-12 border-b border-ink/10">

      {/* Brand block */}
      <div class="lg:col-span-6">
        <a href="/" class="inline-block" aria-label="Elysée Group — home">
          <img
            src={logo.src}
            alt="Elysée"
            width={logo.width}
            height={logo.height}
            class="h-10 md:h-12 w-auto"
            loading="lazy"
          />
        </a>
        <p class="mt-4 font-display font-heavy leading-tight text-xl md:text-2xl text-ink">
          {companyContact.tagline}
        </p>
        <address class="mt-5 not-italic text-sm text-ink/75 leading-relaxed">
          {companyContact.address.line1}<br />
          {companyContact.address.line2}<br />
          {companyContact.address.city}
        </address>
        <dl class="mt-4 space-y-1 text-sm">
          <div class="flex gap-3">
            <dt class="w-12 text-brand-500 uppercase tracking-wider text-[10px] pt-1 font-semibold">Tel</dt>
            <dd>
              <a href={`tel:${companyContact.phone.replace(/[^+\d]/g, '')}`} class="text-ink hover:text-brand-500 transition-colors duration-200">
                {companyContact.phone}
              </a>
            </dd>
          </div>
          <div class="flex gap-3">
            <dt class="w-12 text-brand-500 uppercase tracking-wider text-[10px] pt-1 font-semibold">Fax</dt>
            <dd class="text-ink">{companyContact.fax}</dd>
          </div>
          <div class="flex gap-3">
            <dt class="w-12 text-brand-500 uppercase tracking-wider text-[10px] pt-1 font-semibold">Email</dt>
            <dd>
              <a href={`mailto:${companyContact.email}`} class="text-ink hover:text-brand-500 transition-colors duration-200">
                {companyContact.email}
              </a>
            </dd>
          </div>
        </dl>
      </div>

      {/* Newsletter */}
      <div class="lg:col-span-6 lg:pl-10 lg:border-l lg:border-ink/10">
        <p class="text-[11px] uppercase tracking-[0.3em] text-brand-500 font-semibold">Newsletter</p>
        <h2 class="mt-3 font-display font-heavy leading-tight text-xl md:text-2xl text-ink max-w-md">
          Subscribe to be the first to know about our news and future plans.
        </h2>
        <form
          action="/api/newsletter"
          method="post"
          class="mt-5 flex flex-col sm:flex-row gap-2 max-w-lg"
        >
          <label class="sr-only" for="newsletter-email">Email address</label>
          <input
            id="newsletter-email"
            name="email"
            type="email"
            required
            placeholder="your@email.com"
            autocomplete="email"
            class="flex-1 bg-transparent border border-ink/25 px-4 py-2.5 text-sm text-ink placeholder:text-ink/40 focus:outline-none focus:border-brand-500 transition-colors duration-200"
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2 bg-brand-500 text-surface px-5 py-2.5 text-[11px] uppercase tracking-[0.25em] font-medium hover:bg-brand-700 transition-colors duration-200 cursor-pointer"
          >
            Subscribe
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </button>
        </form>
        <p class="mt-3 text-xs text-ink/55 max-w-lg leading-relaxed">
          By subscribing you agree to our <a href="/legal/privacy-policy/" class="underline underline-offset-2 hover:text-brand-500 transition-colors duration-200">Privacy Policy</a>.
        </p>

        {social.length > 0 && (
          <div class="mt-7">
            <p class="text-[11px] uppercase tracking-[0.3em] text-brand-500 mb-3 font-semibold">Connect</p>
            <ul class="flex items-center gap-2">
              {social.map((s) => (
                <li>
                  <a
                    href={s.href}
                    aria-label={s.label}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center w-9 h-9 border border-ink/20 text-ink/75 hover:text-surface hover:bg-brand-500 hover:border-brand-500 transition-colors duration-200"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={s.icon} />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>

    {/* ===== Link columns row ===== */}
    <div class="py-10 md:py-12 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 md:gap-6">
      {footerNav.map((col) => (
        <div>
          <h2 class="text-[11px] font-semibold uppercase tracking-[0.25em] text-brand-500">{col.title}</h2>
          <ul class="mt-4 space-y-2.5">
            {col.items.map((it) => (
              <li>
                <a
                  class="text-sm text-ink hover:text-brand-500 transition-colors duration-200"
                  href={it.href}
                >
                  {it.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </Container>

  {/* ===== Curved green legal strip ===== */}
  <div class="relative bg-brand-500 text-surface mt-0">
    {/* SVG curve that "carves" green up into the white area above */}
    <svg
      class="absolute left-0 w-full h-[55px] sm:h-[75px] md:h-[95px] pointer-events-none"
      style="top: 1px; transform: translateY(-100%);"
      viewBox="0 0 1440 95"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <path d="M0,20 C360,115 880,100 1440,38 L1440,95 L0,95 Z" fill="#4c6830" />
    </svg>

    <Container size="xl" class="relative py-5 md:py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 text-xs text-surface">
        {/* Logo mark on left */}
        <a href="/" class="inline-flex shrink-0" aria-label="Elysée Group — home">
          <img
            src={logo.src}
            alt="Elysée"
            class="h-7 md:h-8 w-auto brightness-0 invert"
            loading="lazy"
          />
        </a>

        {/* Copyright + legal links — pipe-separated */}
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
          <p>Copyright &copy; {year} Elysee</p>
          {footerLegal.map((it) => (
            <>
              <span aria-hidden="true" class="text-surface/40">|</span>
              <a href={it.href} class="hover:text-surface/80 transition-colors duration-200">{it.label}</a>
            </>
          ))}
        </div>

        {/* Designer credit on right */}
        <p class="shrink-0">
          Designed &amp; Development by
          <a
            href="https://www.itdev.gr"
            target="_blank"
            rel="noopener"
            class="ml-1 hover:text-surface/80 transition-colors duration-200"
          >ITDEV</a>
        </p>
      </div>
    </Container>
  </div>
</footer>

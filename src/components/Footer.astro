---
import Container from './Container.astro';
import { footerNav, footerLegal, social } from '../data/navigation';
import logo from '../assets/icons/elysee-logo.svg';
const year = new Date().getFullYear();
---
<footer class="bg-ink text-surface">
  <Container size="xl" class="py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-10">
      <div>
        <a href="/" class="inline-block" aria-label="Elysse Group — home">
          <img
            src={logo.src}
            alt="Elysee"
            width={logo.width}
            height={logo.height}
            class="h-12 w-auto"
            loading="lazy"
          />
        </a>
      </div>
      {footerNav.map((col) => (
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-surface/80">{col.title}</h2>
          <ul class="mt-4 space-y-2">
            {col.items.map((it) => (
              <li>
                <a
                  class="text-sm text-surface/70 hover:text-surface transition-colors duration-fast"
                  href={it.href}
                >
                  {it.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-surface/10 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-surface/60">
      <p>&copy; Copyright 2020&ndash;{year}</p>
      {social.length > 0 && (
        <div class="flex items-center gap-3">
          {social.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="text-surface/70 hover:text-surface transition-colors duration-fast"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                set:html={s.icon}
              />
            </a>
          ))}
        </div>
      )}
      {footerLegal.length > 0 && (
        <nav aria-label="Legal" class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
          {footerLegal.map((it) => (
            <a class="hover:text-surface transition-colors duration-fast" href={it.href}>{it.label}</a>
          ))}
        </nav>
      )}
      <p>
        Designed &amp; Developed by:
        <a
          href="https://www.itdev.gr"
          target="_blank"
          rel="noopener"
          class="hover:text-surface transition-colors duration-fast"
        >ITDEV</a>
      </p>
    </div>
  </Container>
</footer>

---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from './Button.astro';
import Container from './Container.astro';

interface Props {
  eyebrow?: string;
  heading: string;
  body?: string;
  image: ImageMetadata;
  imageAlt?: string;
  cta?: { label: string; href: string };
  /** Position content horizontally within the panel. */
  align?: 'left' | 'right' | 'center';
  /** Darken the background image for legibility. 0 = none, 1 = black. */
  scrim?: number;
  id?: string;
}

const {
  eyebrow,
  heading,
  body,
  image,
  imageAlt = '',
  cta,
  align = 'left',
  scrim = 0.45,
  id,
} = Astro.props;

const alignCls = {
  left:   'items-start text-left',
  right:  'items-end text-right',
  center: 'items-center text-center',
}[align];
---
<section
  id={id}
  data-snap
  class="relative min-h-[var(--panel-h)] w-full snap-start snap-always scroll-mt-20 md:scroll-mt-24 overflow-hidden bg-ink text-surface flex"
>
  <Image
    src={image}
    alt={imageAlt}
    widths={[768, 1280, 1920, 2400]}
    sizes="100vw"
    loading="lazy"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div
    class="absolute inset-0"
    aria-hidden="true"
    style={`background: linear-gradient(180deg, rgba(10,10,10,${scrim * 0.55}) 0%, rgba(10,10,10,${scrim}) 60%, rgba(10,10,10,${scrim * 1.1}) 100%);`}
  ></div>
  <Container size="xl" class={`relative z-10 flex flex-col justify-end w-full pb-20 md:pb-28 ${alignCls}`}>
    <div class={`max-w-3xl flex flex-col ${alignCls}`}>
      {eyebrow && (
        <p data-reveal class="text-xs md:text-sm uppercase tracking-widest text-surface/80 mb-3 md:mb-4">{eyebrow}</p>
      )}
      <h2 data-reveal data-reveal-delay="80" class="font-display leading-[1.05] text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-surface">
        {heading}
      </h2>
      {body && (
        <p data-reveal data-reveal-delay="160" class="mt-5 md:mt-7 max-w-prose text-base md:text-lg text-surface/90">
          {body.split(/\n\n+/)[0]}
        </p>
      )}
      {cta && (
        <div data-reveal data-reveal-delay="240" class="mt-7 md:mt-9">
          <Button href={cta.href} variant="primary" size="lg">{cta.label}</Button>
        </div>
      )}
    </div>
  </Container>
</section>

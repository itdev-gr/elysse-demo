---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from './Button.astro';
import Container from './Container.astro';

interface Props {
  eyebrow?: string;
  headline: string;
  sub?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  cta?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  align?: 'left' | 'center';
  height?: 'sm' | 'md' | 'lg' | 'screen';
  /** If true, render headline + sub overlaid on the image with a darkening scrim. */
  overlay?: boolean;
}
const {
  eyebrow,
  headline,
  sub,
  image,
  imageAlt = '',
  cta,
  ctaSecondary,
  align = 'left',
  height = 'lg',
  overlay = true,
} = Astro.props;

const heights = {
  sm:     'min-h-[60vh]',
  md:     'min-h-[75vh]',
  lg:     'min-h-[88vh]',
  screen: 'min-h-screen',
};
const aligns = {
  left:   'text-left items-start',
  center: 'text-center items-center mx-auto',
};
---
<section class={`relative ${heights[height]} flex items-end overflow-hidden bg-ink`}>
  {image && (
    <Image
      src={image}
      alt={imageAlt}
      widths={[768, 1440, 2000]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
  )}
  {image && overlay && (
    <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/30 to-transparent" aria-hidden="true"></div>
  )}
  <Container size="xl" class="relative z-10 pb-16 md:pb-24">
    <div class={`flex flex-col ${aligns[align]} max-w-3xl ${align === 'center' ? 'mx-auto' : ''}`}>
      {eyebrow && (
        <p class={`text-xs md:text-sm uppercase tracking-widest mb-3 md:mb-4 ${image && overlay ? 'text-surface/80' : 'text-ink/60'}`}>{eyebrow}</p>
      )}
      <h1 data-reveal class={`font-display leading-tight ${image && overlay ? 'text-surface' : 'text-ink'} text-4xl sm:text-5xl md:text-6xl lg:text-7xl`}>
        {headline}
      </h1>
      {sub && (
        <p data-reveal data-reveal-delay="100" class={`mt-4 md:mt-6 max-w-prose text-base md:text-lg ${image && overlay ? 'text-surface/90' : 'text-ink/70'}`}>
          {sub}
        </p>
      )}
      {(cta || ctaSecondary) && (
        <div data-reveal data-reveal-delay="200" class={`mt-6 md:mt-8 flex flex-wrap gap-3 md:gap-4 ${align === 'center' ? 'justify-center' : ''}`}>
          {cta && <Button href={cta.href} variant="primary" size="lg">{cta.label}</Button>}
          {ctaSecondary && <Button href={ctaSecondary.href} variant="secondary" size="lg">{ctaSecondary.label}</Button>}
        </div>
      )}
    </div>
  </Container>
</section>

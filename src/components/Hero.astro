---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from './Button.astro';
import Container from './Container.astro';

interface Props {
  id?: string;
  eyebrow?: string;
  headline: string;
  sub?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  /** Public-folder URL to a background video (e.g. "/media/hero.mp4"). Takes precedence over `image` for the background layer; `image` is reused as the poster. */
  video?: string;
  cta?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  align?: 'left' | 'center';
  height?: 'sm' | 'md' | 'lg' | 'screen';
  /** If true, render headline + sub overlaid on the image with a darkening scrim. */
  overlay?: boolean;
  /** If true, let the sub paragraph span wider than max-w-prose and stay on one line at lg+. */
  wideSub?: boolean;
}
const {
  id,
  eyebrow,
  headline,
  sub,
  image,
  imageAlt = '',
  video,
  cta,
  ctaSecondary,
  align = 'left',
  height = 'lg',
  overlay = true,
  wideSub = false,
} = Astro.props;

const hasMedia = Boolean(video || image);

const heights = {
  sm:     'min-h-[60vh]',
  md:     'min-h-[75vh]',
  lg:     'min-h-[88vh]',
  screen: 'min-h-[100dvh]',
};
const aligns = {
  left:   'text-left items-start',
  center: 'text-center items-center mx-auto',
};
---
<section id={id} data-hero data-snap={height === 'screen' ? '' : undefined} class={`relative ${heights[height]} ${height === 'screen' ? 'snap-start snap-always scroll-mt-0' : ''} flex items-end overflow-hidden bg-ink`}>
  {video ? (
    <video
      src={video}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover bg-ink"
    ></video>
  ) : image && (
    <Image
      src={image}
      alt={imageAlt}
      widths={[768, 1440, 2000]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
  )}
  {hasMedia && overlay && (
    <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/30 to-transparent" aria-hidden="true"></div>
  )}
  <Container size="xl" class="relative z-10 pb-6 md:pb-10">
    <div class={`flex flex-col ${aligns[align]} ${wideSub ? 'max-w-3xl lg:max-w-none' : 'max-w-3xl'} ${align === 'center' ? 'mx-auto' : ''}`}>
      {eyebrow && (
        <p class={`text-xs md:text-sm uppercase tracking-widest mb-3 md:mb-4 ${hasMedia && overlay ? 'text-surface/80' : 'text-ink/60'}`}>{eyebrow}</p>
      )}
      <h1 data-reveal class={`font-display leading-tight ${hasMedia && overlay ? 'text-surface' : 'text-ink'} text-3xl sm:text-4xl md:text-5xl lg:text-5xl`}>
        {headline}
      </h1>
      {sub && (
        <p data-reveal data-reveal-delay="100" class={`mt-4 md:mt-6 ${wideSub ? 'lg:whitespace-nowrap' : 'max-w-prose'} text-base md:text-lg ${hasMedia && overlay ? 'text-surface/90' : 'text-ink/70'}`}>
          {sub}
        </p>
      )}
      {(cta || ctaSecondary) && (
        <div data-reveal data-reveal-delay="200" class={`mt-6 md:mt-8 flex flex-wrap gap-3 md:gap-4 ${align === 'center' ? 'justify-center' : ''}`}>
          {cta && <Button href={cta.href} variant="primary" size="lg">{cta.label}</Button>}
          {ctaSecondary && <Button href={ctaSecondary.href} variant="secondary" size="lg">{ctaSecondary.label}</Button>}
        </div>
      )}
    </div>
  </Container>
</section>

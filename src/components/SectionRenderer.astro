---
import Container from './Container.astro';
import Section from './Section.astro';
import Card from './Card.astro';
import OfficeCard from './OfficeCard.astro';
import Button from './Button.astro';
import { Image } from 'astro:assets';
import type { Section as SectionData } from '../data/content';

interface Props {
  section: SectionData;
}
const { section } = Astro.props;
---
{section.kind === 'text' && (
  <Section spacing="md">
    <Container size="lg">
      {section.eyebrow && (
        <p class="text-xs uppercase tracking-widest text-brand-500 mb-3">{section.eyebrow}</p>
      )}
      {section.heading && (
        <h2 data-reveal class="font-display text-display-2">{section.heading}</h2>
      )}
      {section.image && (
        <div class="mt-6 overflow-hidden bg-ink/5">
          <Image
            src={section.image}
            alt={section.heading ?? ''}
            widths={[480, 960, 1440]}
            sizes="(min-width: 1024px) 66vw, 100vw"
            class="h-auto w-full object-cover"
          />
        </div>
      )}
      <div class="mt-6 max-w-prose text-ink/80 space-y-4">
        {section.body.split(/\n\n+/).map((p) => <p>{p}</p>)}
      </div>
      {section.cta && (
        <div class="mt-6">
          <Button href={section.cta.href} variant="primary">{section.cta.label}</Button>
        </div>
      )}
    </Container>
  </Section>
)}
{section.kind === 'feature-grid' && (
  <Section bg="alt" spacing="lg">
    <Container size="xl">
      {section.eyebrow && (
        <p class="text-xs uppercase tracking-widest text-brand-500 mb-3">{section.eyebrow}</p>
      )}
      {section.heading && (
        <h2 data-reveal class="font-display text-display-2">{section.heading}</h2>
      )}
      <div class="mt-10 md:mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {section.items.map((item, i) => (
          <Card
            title={item.title}
            eyebrow={item.eyebrow}
            image={item.image}
            href={item.href}
            data-reveal
            data-reveal-delay={String(i * 60)}
          >
            {item.body}
          </Card>
        ))}
      </div>
    </Container>
  </Section>
)}
{section.kind === 'list' && (
  <Section spacing="md">
    <Container size="lg">
      {section.eyebrow && (
        <p class="text-xs uppercase tracking-widest text-brand-500 mb-3">{section.eyebrow}</p>
      )}
      {section.heading && (
        <h2 data-reveal class="font-display text-display-2">{section.heading}</h2>
      )}
      {section.intro && (
        <p class="mt-6 max-w-prose text-ink/80">{section.intro}</p>
      )}
      <ul class="mt-6 space-y-2 list-disc list-inside text-ink/80 max-w-prose">
        {section.items.map((item) => <li>{item}</li>)}
      </ul>
    </Container>
  </Section>
)}
{section.kind === 'offices' && (
  <Section spacing="lg">
    <Container size="xl">
      {section.heading && (
        <h2 data-reveal class="font-display text-display-2">{section.heading}</h2>
      )}
      <div class="mt-10 md:mt-14 grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-8 gap-y-2">
        {section.offices.map((o, i) => (
          <OfficeCard
            city={o.city}
            region={o.region}
            addressLines={o.addressLines}
            phones={o.phones}
            email={o.email}
            data-reveal
            data-reveal-delay={String(i * 60)}
          />
        ))}
      </div>
    </Container>
  </Section>
)}
{section.kind === 'news-list' && (
  <Section bg="alt" spacing="lg">
    <Container size="xl">
      {section.eyebrow && (
        <p class="text-xs uppercase tracking-widest text-brand-500 mb-3">{section.eyebrow}</p>
      )}
      {section.heading && (
        <h2 data-reveal class="font-display text-display-2">{section.heading}</h2>
      )}
      <div class="mt-10 md:mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {section.articles.map((a, i) => (
          <Card
            title={a.title}
            eyebrow={a.date ?? a.eyebrow}
            image={a.image}
            data-reveal
            data-reveal-delay={String(i * 60)}
          >
            {a.excerpt}
          </Card>
        ))}
      </div>
    </Container>
  </Section>
)}

---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image?: ImageMetadata;
  imageAlt?: string;
  title: string;
  eyebrow?: string;
  href?: string;
  aspect?: '4/3' | '16/9' | '1/1' | '3/4';
}
const { image, imageAlt = '', title, eyebrow, href, aspect = '4/3' } = Astro.props;

const Wrapper = href ? 'a' : 'div';
const aspects = {
  '4/3': 'aspect-[4/3]',
  '16/9': 'aspect-video',
  '1/1': 'aspect-square',
  '3/4': 'aspect-[3/4]',
};
---
<Wrapper
  href={href}
  class={[
    'group block overflow-hidden bg-surface-alt',
    'transition-colors duration-base ease-out-quint',
    href ? 'hover:bg-surface' : '',
  ].filter(Boolean).join(' ')}
>
  {image && (
    <div class={`${aspects[aspect]} overflow-hidden bg-ink/5`}>
      <Image
        src={image}
        alt={imageAlt || title}
        widths={[480, 960, 1440]}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        class="h-full w-full object-cover transition-transform duration-slow ease-out-quint group-hover:scale-[1.03]"
      />
    </div>
  )}
  <div class="p-6 md:p-8">
    {eyebrow && (
      <p class="text-xs uppercase tracking-widest text-brand-500 mb-2">{eyebrow}</p>
    )}
    <h3 class="text-2xl md:text-3xl font-display leading-tight">{title}</h3>
    <div class="mt-3 text-sm text-ink/70">
      <slot />
    </div>
    {href && (
      <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-ink group-hover:text-brand-500 transition-colors duration-fast">
        Learn more
        <span aria-hidden="true" class="transition-transform duration-fast group-hover:translate-x-1">&rarr;</span>
      </span>
    )}
  </div>
</Wrapper>

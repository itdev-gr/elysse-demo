---
import type { CatalogProduct } from '~/scripts/catalog/types';
import SpecTable from './SpecTable.astro';
interface Props { product: CatalogProduct; }
const { product: p } = Astro.props;
---
<section class="mt-12 border-t border-ink/10">
  <div role="tablist" class="sticky top-16 z-10 bg-surface border-b border-ink/10 flex gap-2 overflow-x-auto">
    <button role="tab" data-tab="spec" aria-selected="true" class="font-mono text-[11px] uppercase tracking-wider px-4 py-3 border-b-2 border-brand-500">Specifications</button>
    <button role="tab" data-tab="standards" aria-selected="false" class="font-mono text-[11px] uppercase tracking-wider px-4 py-3 border-b-2 border-transparent">Standards</button>
    <button role="tab" data-tab="install" aria-selected="false" class="font-mono text-[11px] uppercase tracking-wider px-4 py-3 border-b-2 border-transparent">Installation</button>
  </div>

  <div role="tabpanel" data-panel="spec" class="py-6">
    <SpecTable product={p} />
  </div>
  <div role="tabpanel" data-panel="standards" class="py-6 hidden">
    {p.standards.length ? (
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {p.standards.map((s: string) => (
          <li class="cat-card p-4">
            <p class="font-mono text-[11px] text-ink/65">Standard</p>
            <p class="font-heavy text-lg mt-1">{s}</p>
          </li>
        ))}
      </ul>
    ) : <p class="text-sm text-ink/70">No standards listed.</p>}
  </div>
  <div role="tabpanel" data-panel="install" class="py-6 hidden">
    {p.installation ? (
      <p class="text-sm text-ink max-w-prose whitespace-pre-line">{p.installation}</p>
    ) : <p class="text-sm text-ink/70">Installation guide coming soon.</p>}
  </div>
</section>

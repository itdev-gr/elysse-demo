---
import Container from './Container.astro';
import logo from '../assets/icons/elysee-logo.svg';
import { megaNav } from '../data/navigation';
---
<div
  data-menu-root
  id="primary-menu"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Primary navigation"
>
  <div
    data-menu-backdrop
    class="absolute inset-0 bg-brand-500/0 opacity-0 transition-opacity duration-base ease-out-quint"
  ></div>
  <aside
    data-menu-drawer
    class="absolute inset-0 bg-brand-500 text-surface translate-y-2 opacity-0 transition-[transform,opacity] duration-base ease-out-quint overflow-y-auto"
  >
    <Container size="xl" class="min-h-screen flex flex-col py-6 md:py-8">
      {/* Top bar */}
      <div class="grid grid-cols-3 items-center">
        <span aria-hidden="true"></span>
        <a href="/" class="justify-self-center inline-flex" aria-label="Home" data-menu-link>
          <img
            src={logo.src}
            width={logo.width}
            height={logo.height}
            alt="Elysee"
            class="h-10 md:h-12 w-auto"
          />
        </a>
        <button
          data-menu-close
          type="button"
          class="justify-self-end inline-flex items-center gap-3 px-2 py-2 text-sm md:text-base uppercase tracking-widest font-medium text-surface hover:text-brand-accent transition-colors duration-fast"
          aria-label="Close menu"
        >
          <span>Close menu</span>
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 6l16 16M6 22L22 6" />
          </svg>
        </button>
      </div>

      {/* 3-column grid */}
      <nav class="flex-1 mt-12 md:mt-20 grid grid-cols-1 md:grid-cols-3 gap-x-12 gap-y-12 md:gap-y-16 pb-12" aria-label="Site sections">
        {megaNav.map((column) => (
          <div class="flex flex-col gap-12 md:gap-16">
            {column.map((group) => (
              <div>
                {group.href ? (
                  <a
                    href={group.href}
                    class="inline-block text-2xl md:text-3xl font-sans font-heavy text-surface hover:text-brand-accent transition-colors duration-fast"
                    data-menu-link
                  >
                    {group.title}
                  </a>
                ) : (
                  <span class="text-2xl md:text-3xl font-sans font-heavy text-surface">{group.title}</span>
                )}
                <ul class="mt-5 space-y-2">
                  {group.items.map((it) => (
                    <li>
                      <a
                        href={it.href}
                        class="inline-flex items-baseline gap-2 text-xs md:text-sm uppercase tracking-widest text-surface/85 hover:text-brand-accent transition-colors duration-fast"
                        data-menu-link
                      >
                        <span aria-hidden="true" class="text-surface/60">&gt;</span>
                        <span>{it.label}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </nav>
    </Container>
  </aside>
</div>

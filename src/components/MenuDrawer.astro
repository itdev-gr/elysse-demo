---
import Container from './Container.astro';
import { primaryNav } from '../data/navigation';
---
<div
  data-menu-root
  id="primary-menu"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Primary navigation"
>
  <div data-menu-backdrop class="absolute inset-0 bg-ink/60 opacity-0 transition-opacity duration-base"></div>
  <aside
    data-menu-drawer
    class="absolute right-0 top-0 h-full w-full max-w-md bg-surface translate-x-full transition-transform duration-base ease-out-quint shadow-none"
  >
    <Container size="full" class="flex h-full flex-col">
      <div class="flex items-center justify-between py-4 md:py-5">
        <span class="text-sm uppercase tracking-wide text-ink-muted">Menu</span>
        <button
          data-menu-close
          class="inline-flex items-center justify-center p-2 -mr-2 text-ink hover:text-brand-500 transition-colors duration-fast"
          aria-label="Close menu"
          type="button"
        >
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 6l16 16M6 22L22 6" />
          </svg>
        </button>
      </div>
      <nav class="flex flex-1 flex-col gap-1 py-6" aria-label="Primary">
        {primaryNav.map((item) => (
          <a
            href={item.href}
            class="group flex items-center justify-between py-3 text-2xl md:text-3xl font-display border-b border-ink/10 transition-colors duration-fast hover:text-brand-500"
            data-menu-link
          >
            <span>{item.label}</span>
            <span class="text-base text-ink-muted transition-transform duration-fast group-hover:translate-x-1" aria-hidden="true">→</span>
          </a>
        ))}
      </nav>
    </Container>
  </aside>
</div>

---
interface Props {
  /** Two-digit chapter number, e.g. "01". */
  number: string;
  /** Chapter label, e.g. "Chapter One". */
  label: string;
  /** Section heading text. */
  title: string;
  /** Optional lead paragraph rendered under the heading. */
  lead?: string;
  /** Width cap for the header block. */
  maxWidth?: 'narrow' | 'wide';
  /**
   * Layout variant. Each About Us page picks a different one so the section
   * rhythm reads distinctly while the design tokens stay identical.
   * - default    — big translucent NN on top (canonical)
   * - centered   — NN/label/title centered, accent line below
   * - right      — NN/label in right column, title spans left
   * - inline     — small NN inline before the title, no big number
   * - lead-first — lead paragraph above, NN/title block reads as a signature
   */
  variant?: 'default' | 'centered' | 'right' | 'inline' | 'lead-first';
}

const { number, label, title, lead, maxWidth = 'narrow', variant = 'default' } = Astro.props;
const cap = maxWidth === 'wide' ? 'max-w-4xl' : 'max-w-2xl';
---
{variant === 'default' && (
  <header class={`${cap} mb-12 md:mb-16`}>
    <div data-reveal aria-hidden="true" class="font-display font-heavy leading-none text-7xl md:text-8xl text-brand-500/15 tracking-tighter">{number}</div>
    <p data-reveal data-reveal-delay="80" class="mt-4 text-[11px] md:text-xs uppercase tracking-[0.3em] text-ink/60">{label}</p>
    <h2 data-reveal data-reveal-delay="160" class="mt-5 font-display font-heavy leading-tight text-3xl md:text-4xl lg:text-5xl text-ink">{title}</h2>
    <div data-reveal data-reveal-delay="240" aria-hidden="true" class="mt-8 h-px w-16 bg-accent"></div>
    {lead && (
      <p data-reveal data-reveal-delay="320" class="mt-8 text-lg md:text-xl text-ink/80 leading-relaxed">{lead}</p>
    )}
  </header>
)}

{variant === 'centered' && (
  <header class={`${cap} mx-auto text-center mb-12 md:mb-16`}>
    <div data-reveal aria-hidden="true" class="font-display font-heavy leading-none text-7xl md:text-8xl text-brand-500/15 tracking-tighter">{number}</div>
    <p data-reveal data-reveal-delay="80" class="mt-4 text-[11px] md:text-xs uppercase tracking-[0.3em] text-ink/60">{label}</p>
    <h2 data-reveal data-reveal-delay="160" class="mt-5 font-display font-heavy leading-tight text-3xl md:text-4xl lg:text-5xl text-ink">{title}</h2>
    <div data-reveal data-reveal-delay="240" aria-hidden="true" class="mt-8 h-px w-16 bg-accent mx-auto"></div>
    {lead && (
      <p data-reveal data-reveal-delay="320" class="mt-8 text-lg md:text-xl text-ink/80 leading-relaxed mx-auto">{lead}</p>
    )}
  </header>
)}

{variant === 'right' && (
  <header class="mb-12 md:mb-16">
    <div class="grid grid-cols-12 gap-6 md:gap-10 items-start">
      <div class="col-span-12 md:col-span-8 order-2 md:order-1">
        <h2 data-reveal data-reveal-delay="160" class="font-display font-heavy leading-tight text-3xl md:text-4xl lg:text-5xl text-ink">{title}</h2>
        <div data-reveal data-reveal-delay="240" aria-hidden="true" class="mt-8 h-px w-16 bg-accent"></div>
      </div>
      <div class="col-span-12 md:col-span-4 order-1 md:order-2 md:text-right">
        <div data-reveal aria-hidden="true" class="font-display font-heavy leading-none text-6xl md:text-7xl text-brand-500/15 tracking-tighter">{number}</div>
        <p data-reveal data-reveal-delay="80" class="mt-3 text-[11px] md:text-xs uppercase tracking-[0.3em] text-ink/60">{label}</p>
      </div>
    </div>
    {lead && (
      <p data-reveal data-reveal-delay="320" class={`mt-8 text-lg md:text-xl text-ink/80 leading-relaxed ${cap}`}>{lead}</p>
    )}
  </header>
)}

{variant === 'inline' && (
  <header class={`${cap} mb-12 md:mb-16`}>
    <div data-reveal class="flex items-baseline gap-4 md:gap-5">
      <span aria-hidden="true" class="font-display font-heavy leading-none text-2xl md:text-3xl text-brand-500 tracking-tight">{number}</span>
      <span aria-hidden="true" class="text-ink/30">·</span>
      <p class="text-[11px] md:text-xs uppercase tracking-[0.3em] text-ink/60">{label}</p>
    </div>
    <h2 data-reveal data-reveal-delay="120" class="mt-5 font-display font-heavy leading-tight text-3xl md:text-4xl lg:text-5xl text-ink">{title}</h2>
    <div data-reveal data-reveal-delay="200" aria-hidden="true" class="mt-8 h-px w-16 bg-accent"></div>
    {lead && (
      <p data-reveal data-reveal-delay="280" class="mt-8 text-lg md:text-xl text-ink/80 leading-relaxed">{lead}</p>
    )}
  </header>
)}

{variant === 'lead-first' && (
  <header class={`${cap} mb-12 md:mb-16`}>
    {lead && (
      <p data-reveal class="text-lg md:text-xl text-ink/80 leading-relaxed mb-10 md:mb-12">{lead}</p>
    )}
    <div data-reveal data-reveal-delay="80" aria-hidden="true" class="h-px w-16 bg-accent mb-8"></div>
    <div data-reveal data-reveal-delay="160" aria-hidden="true" class="font-display font-heavy leading-none text-7xl md:text-8xl text-brand-500/15 tracking-tighter">{number}</div>
    <p data-reveal data-reveal-delay="240" class="mt-4 text-[11px] md:text-xs uppercase tracking-[0.3em] text-ink/60">{label}</p>
    <h2 data-reveal data-reveal-delay="320" class="mt-5 font-display font-heavy leading-tight text-3xl md:text-4xl lg:text-5xl text-ink">{title}</h2>
  </header>
)}

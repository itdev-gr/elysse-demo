---
interface Props {
  /** Figure index — used for caption tag and pattern id (must be unique per page). */
  index: number;
  /** Long caption text. */
  caption: string;
  /** Optional image src from /public (e.g. "/images/about/hq-aerial.jpg"). Renders as <img>; falls back to a placeholder pattern when omitted. */
  src?: string;
  /** Short factual alt text — required when src is provided. */
  alt?: string;
  /** Aspect ratio — default editorial 21:9. */
  ratio?: '21/9' | '16/9' | '4/3';
}

const { index, caption, src, alt, ratio = '21/9' } = Astro.props;
const patternId = `diag-fig-${index}`;
const aspectClass = ratio === '16/9' ? 'aspect-[16/9]' : ratio === '4/3' ? 'aspect-[4/3]' : 'aspect-[21/9]';
---
<figure data-reveal class="bg-surface-alt border-y border-ink/15">
  <div class={`relative ${aspectClass} overflow-hidden`}>
    {src ? (
      <img
        src={src}
        alt={alt ?? caption}
        width="2000"
        height="858"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
    ) : (
      <>
        <svg class="absolute inset-0 w-full h-full text-ink/10" aria-hidden="true" preserveAspectRatio="none">
          <defs>
            <pattern id={patternId} width="24" height="24" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
              <line x1="0" y1="0" x2="0" y2="24" stroke="currentColor" stroke-width="1" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill={`url(#${patternId})`} />
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 text-ink/40">
          <svg class="w-10 h-10 md:w-12 md:h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="1" />
            <circle cx="8.5" cy="10" r="1.5" />
            <path d="m21 15-3.5-4.5L12 17" />
          </svg>
          <span class="text-[10px] uppercase tracking-[0.3em]">Image placeholder</span>
        </div>
      </>
    )}
  </div>
  <figcaption class="bg-surface border-t border-ink/15">
    <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8 py-4 md:py-5 text-sm">
      <span class="text-ink/70">{caption}</span>
    </div>
  </figcaption>
</figure>

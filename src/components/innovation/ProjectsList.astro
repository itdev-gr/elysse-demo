---
import ProjectCard from './ProjectCard.astro';

interface Project {
  name: string;
  status: 'Ongoing' | 'Completed';
  duration: string;
  totalFunding: string;
  elyseeFunding?: string;
  description?: string;
  image: string;
  href?: string;
}
interface Props {
  heading?: string;
  items: Project[];
}
const { heading, items } = Astro.props;
---
<section class="my-10 md:my-14">
  {heading && (
    <h2 data-reveal class="text-2xl md:text-3xl font-heavy text-ink mb-6">{heading}</h2>
  )}
  <div class="space-y-6 md:space-y-8">
    {items.map((p, i) => <ProjectCard project={p} index={i} />)}
  </div>
</section>

---
import { getCollection } from 'astro:content';
import { navGroups } from '../data/navigation';
import MegaNav from './nav/MegaNav.tsx';

const productCategories = (await getCollection('categories'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((c) => ({
    name: c.data.name,
    slug: c.data.slug ?? c.id,
    image: c.data.image,
  }));
---
<MegaNav client:load groups={navGroups} productCategories={productCategories} />

<noscript>
  <nav class="ml-auto hidden lg:flex items-stretch gap-1" aria-label="Primary">
    {navGroups.map((group) => (
      <a
        href={group.href || '#'}
        class="inline-flex items-center gap-1 px-3 py-2 text-xs uppercase tracking-widest font-medium hover:text-brand-accent transition-colors duration-fast"
      >
        {group.title}
      </a>
    ))}
  </nav>
</noscript>

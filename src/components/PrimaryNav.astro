---
import { getCollection } from 'astro:content';
import { navGroups, type NavItem } from '../data/navigation';
import MegaNav from './nav/MegaNav.tsx';

// Build the Products mega-panel from the `categories` content collection so
// the 13 product categories render as image cards (same layout as Innovation).
const productItems: NavItem[] = (await getCollection('categories'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((c) => ({
    label: c.data.name,
    // `?country=ask` forces the country picker to open even if a country is
    // already stored — see the entry script in src/pages/catalog/[category]/index.astro.
    href: `/catalog/${c.data.slug ?? c.id}/?country=ask`,
    image: c.data.image,
    caption: c.data.blurb,
  }));

const groupsForNav = navGroups.map((g) =>
  g.title === 'Products' ? { ...g, items: productItems } : g,
);
---
<MegaNav client:load groups={groupsForNav} />

<noscript>
  <nav class="ml-auto hidden lg:flex items-stretch gap-1" aria-label="Primary">
    <a
      href="/"
      class="inline-flex items-center px-3 py-2 text-xs uppercase tracking-widest font-medium hover:text-brand-accent transition-colors duration-fast"
    >
      Home
    </a>
    {groupsForNav.map((group) => (
      <a
        href={group.href || '#'}
        class="inline-flex items-center gap-1 px-3 py-2 text-xs uppercase tracking-widest font-medium hover:text-brand-accent transition-colors duration-fast"
      >
        {group.title}
      </a>
    ))}
  </nav>
</noscript>

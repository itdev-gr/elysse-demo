---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SnapSection from '../components/SnapSection.astro';
import SnapNav, { type SnapNavItem } from '../components/SnapNav.astro';
import Container from '../components/Container.astro';
import Card from '../components/Card.astro';
import { homePage as page, servicesCards } from '../data/content';

// Split sections so text sections become full-screen image panels
// and the news list becomes its own snap panel.
const textSections = page.sections.filter(
  (s): s is Extract<typeof s, { kind: 'text' }> => s.kind === 'text',
);
const newsSection = page.sections.find(
  (s): s is Extract<typeof s, { kind: 'news-list' }> => s.kind === 'news-list',
);

// Stable kebab-case id per panel
const slugify = (s: string) =>
  s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

const HERO_ID = 'panel-hero';
const NEWS_ID = 'panel-news';

const textIds = textSections.map((s) => `panel-${slugify(s.eyebrow ?? s.heading ?? 'section')}`);

const navItems: SnapNavItem[] = [
  { id: HERO_ID, label: 'Top' },
  ...textSections.map((s, i) => ({
    id: textIds[i],
    label: s.eyebrow ?? s.heading ?? `Section ${i + 1}`,
  })),
  ...(newsSection ? [{ id: NEWS_ID, label: newsSection.heading ?? 'News' }] : []),
];
---
<BaseLayout
  title={page.meta.title}
  description={page.meta.description}
  padForHeader={false}
>
  <script is:inline>
    document.documentElement.setAttribute('data-snap-page', '');
    addEventListener('beforeunload', () => {
      document.documentElement.removeAttribute('data-snap-page');
    });
  </script>
  <script>
    import '../scripts/home-snap.client';
  </script>

  <SnapNav items={navItems} />

  {/* Panel 1 — Hero */}
  {page.hero && <Hero id={HERO_ID} {...page.hero} height="screen" />}

  {/* Panels 2..N — one full-screen image per text section.
       The Services panel is special-cased: instead of a single CTA it renders
       a 4-card row at the bottom, one per service sector. */}
  {textSections.map((s, i) => (
    s.eyebrow === 'Services' ? (
      <section
        id={textIds[i]}
        data-snap
        class="relative min-h-[100dvh] w-full snap-start snap-always overflow-hidden bg-ink text-surface flex flex-col"
      >
        <Image
          src={s.image!}
          alt={s.heading ?? ''}
          widths={[768, 1280, 1920, 2400]}
          sizes="100vw"
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div
          class="absolute inset-0"
          aria-hidden="true"
          style="background: linear-gradient(180deg, rgba(10,10,10,0.25) 0%, rgba(10,10,10,0.45) 60%, rgba(10,10,10,0.5) 100%);"
        ></div>
        <Container size="xl" class="relative z-10 flex flex-col justify-between w-full pt-28 md:pt-32 pb-12 md:pb-16">
          <div class="max-w-3xl">
            {s.eyebrow && (
              <p data-reveal class="text-xs md:text-sm uppercase tracking-widest text-surface/80 mb-3 md:mb-4">{s.eyebrow}</p>
            )}
            <h2 data-reveal data-reveal-delay="80" class="font-display leading-[1.05] text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-surface">
              {s.heading}
            </h2>
            {s.body && (
              <p data-reveal data-reveal-delay="160" class="mt-5 md:mt-7 max-w-prose text-base md:text-lg text-surface/90">
                {s.body.split(/\n\n+/)[0]}
              </p>
            )}
          </div>

          <div class="mt-8 md:mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
            {servicesCards.map((c, ci) => (
              <Card
                title={c.label}
                href={c.href}
                image={c.image}
                class="bg-surface/95 text-ink backdrop-blur-sm"
                data-reveal
                data-reveal-delay={String(240 + ci * 60)}
              >
                {c.blurb}
              </Card>
            ))}
          </div>
        </Container>
      </section>
    ) : (
      <SnapSection
        id={textIds[i]}
        eyebrow={s.eyebrow}
        heading={s.heading ?? ''}
        body={s.body}
        image={s.image!}
        imageAlt={s.heading}
        cta={s.cta}
      />
    )
  ))}

  {/* Final panel — Latest News (3-up grid, full screen) */}
  {newsSection && (
    <section
      id={NEWS_ID}
      data-snap
      data-light-bg
      class="relative min-h-[100dvh] snap-start snap-always scroll-mt-0 bg-surface-alt flex items-center py-20 md:py-28"
    >
      <Container size="xl" class="w-full">
        {newsSection.eyebrow && (
          <p data-reveal class="text-xs uppercase tracking-widest text-brand-500 mb-3">
            {newsSection.eyebrow}
          </p>
        )}
        {newsSection.heading && (
          <h2
            data-reveal
            data-reveal-delay="80"
            class="font-display text-4xl md:text-5xl lg:text-6xl"
          >
            {newsSection.heading}
          </h2>
        )}
        <div class="mt-10 md:mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {newsSection.articles.map((a, i) => (
            <Card
              title={a.title}
              eyebrow={a.date ?? a.eyebrow}
              image={a.image}
              data-reveal
              data-reveal-delay={String(160 + i * 80)}
            />
          ))}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>

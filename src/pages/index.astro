---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Slider from '../components/Slider.astro';
import Input from '../components/Input.astro';
import Textarea from '../components/Textarea.astro';
import OfficeCard from '../components/OfficeCard.astro';
import heroImage from '../assets/images/ocean-1440x900.jpg';
import card1 from '../assets/images/shutterstock-377226832-fuel-products.jpg';
import card2 from '../assets/images/shutterstock-377226832-biofuels.jpg';
import card3 from '../assets/images/shutterstock-377226832-advisory-services.jpg';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sonan Bunkers &mdash; smoke test</title>
</head>
<body class="min-h-screen">
  <Header />
  <main>
    <Hero
      eyebrow="Marine Energy"
      headline="Fuelling the journey ahead"
      sub="A leading provider of bunker fuels and energy advisory services for the global maritime industry."
      image={heroImage}
      imageAlt="Container ship at sea"
      cta={{ label: 'Our Services', href: '/our-services/' }}
      ctaSecondary={{ label: 'Contact us', href: '/contact/' }}
    />
    <Section bg="alt" spacing="lg">
      <Container size="xl">
        <h2 class="text-display-2 font-display">What we do</h2>
        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          <Card title="Fuel Products" eyebrow="Service" image={card1} href="/our-services/fuel-products/">
            Conventional and low-sulphur marine fuels delivered worldwide.
          </Card>
          <Card title="Alternative Fuels" eyebrow="Service" image={card2} href="/our-services/alternative-fuels/">
            Biofuels, LNG and electricity for the energy transition.
          </Card>
          <Card title="Advisory" eyebrow="Service" image={card3} href="/our-services/advisory-services/">
            Risk management, hedging and procurement consulting.
          </Card>
        </div>
      </Container>
    </Section>
    <Section spacing="lg">
      <Container size="xl">
        <h2 class="text-display-2 font-display">News</h2>
        <div class="mt-12">
          <Slider id="news" autoplayMs={5000} perView={3}>
            <article data-slide-basis="1/3" class="pr-6">
              <div class="bg-surface-alt p-6">
                <p class="text-xs uppercase tracking-widest text-brand-500">News</p>
                <h3 class="mt-2 text-xl font-display">Slide 1</h3>
                <p class="mt-3 text-sm text-ink/70">Placeholder slide content.</p>
              </div>
            </article>
            <article data-slide-basis="1/3" class="pr-6">
              <div class="bg-surface-alt p-6">
                <p class="text-xs uppercase tracking-widest text-brand-500">News</p>
                <h3 class="mt-2 text-xl font-display">Slide 2</h3>
                <p class="mt-3 text-sm text-ink/70">Placeholder slide content.</p>
              </div>
            </article>
            <article data-slide-basis="1/3" class="pr-6">
              <div class="bg-surface-alt p-6">
                <p class="text-xs uppercase tracking-widest text-brand-500">News</p>
                <h3 class="mt-2 text-xl font-display">Slide 3</h3>
                <p class="mt-3 text-sm text-ink/70">Placeholder slide content.</p>
              </div>
            </article>
            <article data-slide-basis="1/3" class="pr-6">
              <div class="bg-surface-alt p-6">
                <p class="text-xs uppercase tracking-widest text-brand-500">News</p>
                <h3 class="mt-2 text-xl font-display">Slide 4</h3>
                <p class="mt-3 text-sm text-ink/70">Placeholder slide content.</p>
              </div>
            </article>
            <article data-slide-basis="1/3" class="pr-6">
              <div class="bg-surface-alt p-6">
                <p class="text-xs uppercase tracking-widest text-brand-500">News</p>
                <h3 class="mt-2 text-xl font-display">Slide 5</h3>
                <p class="mt-3 text-sm text-ink/70">Placeholder slide content.</p>
              </div>
            </article>
          </Slider>
        </div>
      </Container>
    </Section>
    <Section bg="default" spacing="md">
      <Container size="lg">
        <h2 class="text-display-2 font-display">Forms + Offices</h2>
        <form class="mt-8 grid gap-4 max-w-md" action="#" method="post">
          <Input name="name" label="Name" required />
          <Input name="email" type="email" label="Email" required />
          <Textarea name="message" label="Message" required />
          <button type="submit" class="btn-primary inline-flex items-center justify-center px-6 py-3 bg-brand-500 text-surface uppercase tracking-wide text-sm font-medium rounded-btn hover:bg-brand-600 transition-colors duration-fast">Send</button>
        </form>
        <div class="mt-12 grid sm:grid-cols-2 gap-6">
          <OfficeCard
            city="London"
            region="United Kingdom"
            addressLines={['12 Example Street', 'London EC1A 1BB']}
            phones={['+44 20 0000 0000']}
            email="london@sonanbunkers.com"
          />
          <OfficeCard
            city="Athens"
            region="Greece"
            addressLines={['1 Example Avenue', 'Athens 11743']}
            phones={['+30 21 0000 0000']}
            email="athens@sonanbunkers.com"
          />
        </div>
      </Container>
    </Section>
  </main>
  <Footer />
</body>
</html>

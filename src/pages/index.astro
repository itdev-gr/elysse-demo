---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Card from '../components/Card.astro';
import heroImage from '../assets/images/ocean-1440x900.jpg';
import card1 from '../assets/images/shutterstock-377226832-fuel-products.jpg';
import card2 from '../assets/images/shutterstock-377226832-biofuels.jpg';
import card3 from '../assets/images/shutterstock-377226832-advisory-services.jpg';
---
<BaseLayout
  title="Sonan Bunkers"
  description="A leading provider of bunker fuels and energy advisory services for the global maritime industry."
>
  <Hero
    eyebrow="Marine Energy"
    headline="Fuelling the journey ahead"
    sub="Bunker fuels, alternative energy, and advisory services for the global maritime industry."
    image={heroImage}
    cta={{ label: 'Our Services', href: '/our-services/' }}
    ctaSecondary={{ label: 'Contact us', href: '/contact/' }}
  />
  <Section bg="alt" spacing="lg">
    <Container size="xl">
      <h2 class="font-display text-display-2">What we do</h2>
      <div class="mt-10 md:mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        <Card title="Fuel Products" eyebrow="Service" image={card1} href="/our-services/fuel-products/">Conventional and low-sulphur marine fuels delivered worldwide.</Card>
        <Card title="Alternative Fuels" eyebrow="Service" image={card2} href="/our-services/alternative-fuels/">Biofuels, LNG and electricity for the energy transition.</Card>
        <Card title="Advisory" eyebrow="Service" image={card3} href="/our-services/advisory-services/">Risk management, hedging and procurement consulting.</Card>
      </div>
    </Container>
  </Section>
</BaseLayout>

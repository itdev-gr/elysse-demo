---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionRenderer from '../../components/SectionRenderer.astro';
import Container from '../../components/Container.astro';
import { privacyPolicyPage as page } from '../../data/content';
---
<BaseLayout title={page.meta.title} description={page.meta.description}>
  {page.hero && <Hero {...page.hero} height="md" />}
  <Container size="md" class="py-12 md:py-16 prose prose-stone max-w-prose">
    {page.sections.length > 0
      ? page.sections.map((section) => <SectionRenderer section={section} />)
      : (
        <p>
          This policy is currently being migrated. For the full text, see
          {' '}<a href="https://www.sonanbunkers.com/legal/privacy-policy/">the original page</a>.
        </p>
      )
    }
  </Container>
</BaseLayout>

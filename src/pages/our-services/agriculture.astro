---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionRenderer from '../../components/SectionRenderer.astro';
import Container from '../../components/Container.astro';
import { agriculturePage as page, servicesSiblings } from '../../data/content';
const currentPath = '/our-services/agriculture/';
---
<BaseLayout title={page.meta.title} description={page.meta.description}>
  {page.hero && <Hero {...page.hero} />}
  <Container size="xl" class="py-12 md:py-16 grid lg:grid-cols-[16rem_1fr] gap-12">
    <aside class="order-2 lg:order-1">
      <h2 class="text-xs uppercase tracking-widest text-ink-muted mb-4">Our Services</h2>
      <nav aria-label="Services">
        <ul class="space-y-1 text-sm">
          {servicesSiblings.map((s) => (
            <li>
              <a
                href={s.href}
                aria-current={s.href === currentPath ? 'page' : undefined}
                class={`block px-3 py-2 -mx-3 transition-colors duration-fast ${s.href === currentPath ? 'bg-brand-500 text-surface' : 'text-ink hover:text-brand-500'}`}
              >{s.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
    <div class="order-1 lg:order-2 min-w-0">
      {page.sections.map((section) => <SectionRenderer section={section} />)}
    </div>
  </Container>
</BaseLayout>
